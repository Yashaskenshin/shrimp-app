# Copy to `.env` for local development (`cp .env.example .env` on macOS/Linux).

# SQLite (default local — file is gitignored)
DATABASE_URL="file:./dev.db"

# --- Production (Vercel + hosted Postgres) ---
# Use Neon, Supabase, Railway Postgres, etc. Prisma schema must use
# `provider = "postgresql"` and migrations applied for Postgres.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
